<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Book <%= listing.title %></title>
  <link rel="stylesheet" href="style.css">
 <style> /* Airbnb pink-red */

 /* ----------------------------------------------------
   BOOKING PAGE - Airbnb Style with Plus Jakarta Sans
---------------------------------------------------- */

body {
  font-family: 'Plus Jakarta Sans', sans-serif;
  background-color: #f2f2f2;
  margin: 0;
  padding: 0;
  color: #333;
}

/* Booking Container */
.booking-wrap {
  max-width: 900px;
  margin: 40px auto;
  padding: 0 15px;
}

/* Booking Card */
.book-card {
  background: #ffffff;
  border-radius: 1rem;
  padding: 25px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.06);
  border: 1px solid #e5e7eb;
}

/* Top Section */
.book-top {
  display: flex;
  gap: 25px;
  margin-bottom: 25px;
  align-items: center;
}

/* Large Listing Image */
.listing-thumb {
  width: 320px;
  height: 240px;
  border-radius: 1rem;
  object-fit: cover;
  background: #eee;
  box-shadow: 0 4px 8px rgba(0,0,0,0.08);
}

/* Meta Info */
.book-meta h2 {
  font-size: 28px;
  font-weight: bold;
  margin: 0;
  color: #1f1049;
}

.price {
  margin-top: 8px;
  font-size: 22px;
  font-weight: 700;
  color: #530467;
}

.help-text {
  margin-top: 8px;
  font-size: 15px;
  color: gray;
}

/* Form */
.book-form {
  margin-top: 10px;
}

.form-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 18px;
}

.form-row label {
  font-size: 15px;
  font-weight: 600;
  margin-bottom: 6px;
  color: #222;
}

.form-row input {
  padding: 12px 14px;
  border-radius: 10px;
  border: 1px solid #cfd5dd;
  font-size: 15px;
  background: #fff;
  transition: 0.25s ease;
}

.form-row input:focus {
  border-color: #530467;
  outline: none;
  box-shadow: 0 0 0 3px rgba(83, 4, 103, 0.25);
}

/* Submit Button */
.submit-wrap {
  margin-top: 25px;
}

.btn-confirm {
  width: 100%;
  padding: 14px;
  border-radius: 30px;
  border: none;
  font-size: 18px;
  font-weight: bold;
  cursor: pointer;
  background-color: #1f1049;
  color: #fff;
  transition: all 0.3s ease;
}

.btn-confirm:hover {
  background-color: #037b35;
  transform: translateY(-2px);
  box-shadow: 0 4px 10px rgba(0,0,0,0.15);
}

.btn-confirm:active {
  transform: translateY(0);
}

/* TOP SECTION – Image full width */
.book-top {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-bottom: 25px;
}

/* Full-width Hero Image */
.listing-thumb {
  width: 100%;
  height: 300px;
  border-radius: 1rem;
  object-fit: cover;
  background: #eee;
  box-shadow: 0 4px 8px rgba(0,0,0,0.08);
}

/* Meta info below image */
.book-meta {
  padding: 5px 5px;
}

.book-meta h2 {
  font-size: 28px;
  font-weight: 700;
  margin: 0;
  color: #1f1049;
}

.price {
  margin-top: 10px;
  font-size: 22px;
  font-weight: 600;
  color: #530467;
}

.help-text {
  margin-top: 8px;
  font-size: 15px;
  color: gray;
}

/* Vehicle Dropdown Styling */
.form-row select {
  padding: 12px 14px;
  border-radius: 10px;
  border: 1px solid #cfd5dd;
  font-size: 15px;
  background: #fff;
  transition: 0.25s ease;
  cursor: pointer;
}

/* Hover and focus effects */
.form-row select:hover {
  border-color: #530467;
}

.form-row select:focus {
  border-color: #530467;
  outline: none;
  box-shadow: 0 0 0 3px rgba(83, 4, 103, 0.25);
}

/* Placeholder / default option style */
.form-row select option[value=""] {
  color: #9ca3af; /* Gray placeholder text */
}

/* Optional: consistent height with inputs */
.form-row select {
  height: 44px;
}

/* Responsive adjustments */
@media (max-width: 768px) {
  .form-row select {
    width: 100%;
  }
}


/* Mobile Responsive */
@media (max-width: 768px) {
  .listing-thumb {
    height: 240px;
  }
}


/* Responsive */
@media (max-width: 768px) {
  .book-top {
    flex-direction: column;
    text-align: center;
  }

  .listing-thumb {
    width: 100%;
    height: 260px;
  }
}

  
</style>

</head>
<body class="<% 
  const themeClass = (typeof theme !== 'undefined' && theme) ? theme : ((typeof locals !== 'undefined' && locals.theme) ? locals.theme : '');
%><%= themeClass %>">
  <%- include('../layouts/navbar.ejs') %>

  <div class="container booking-wrap">
    <div class="book-card">
      <div class="book-top">
        <% 
          let imageUrl = null;
          if (listing.image) {
            imageUrl = (typeof listing.image === 'string') ? listing.image : (listing.image.url || null);
          }
        %>
        <% if (imageUrl) { %>
          <img src="<%= imageUrl %>" alt="<%= listing.title %>" class="listing-thumb" onerror="this.style.display='none'"/>
        <% } else { %>
          <div class="listing-thumb" style="display:flex;align-items:center;justify-content:center;color:#9aa4b2">No image</div>
        <% } %>

        <div class="book-meta">
          <h2><%= listing.title %></h2>
          <div class="price">&#8377;<%= listing.price %> <span style="font-weight:500;color:#6b7280">/ night</span></div>
          <div class="help-text"><%= listing.location %> · <%= listing.country %></div>
        </div>
      </div>

      <form class="book-form" method="POST" action="/bookings">
        <input type="hidden" name="listingId" value="<%= listing._id %>">

        <div class="form-row">
          <label for="checkIn">Check-in</label>
          <input id="checkIn" name="checkInDate" type="date" required />
        </div>

        <div class="form-row">
          <label for="checkOut">Check-out</label>
          <input id="checkOut" name="checkOutDate" type="date" required />
        </div>

        <div class="form-row">
          <label for="guests">Guests</label>
          <input id="guests" name="guests" type="number" min="1" value="1" required />
        </div>

        <% if (listing.vehicles && listing.vehicles.length > 0) { %>
          <div class="form-row">
            <label for="vehicle">Select Vehicle</label>
            <select id="vehicle" name="vehicle" class="form-control" required>
              <option value="">-- Choose a vehicle --</option>
              <% listing.vehicles.forEach(v => { %>
                <option value="<%= v %>"><%= v %></option>
              <% }); %>
            </select>
          </div>
        <% } %>

        <div class="submit-wrap">
          <button type="submit" class="btn-confirm">Confirm Booking</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>