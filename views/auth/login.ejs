<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Login</title>
  <style>
 body {
  font-family: Arial, sans-serif;
  background-color: lightblue;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.auth-page {
  width: 100%;
  max-width: 400px;
}

.auth-card {
  background-color: white;
  border: 1px solid #ccc;
  border-radius: 8px;
  padding: 30px;
}

.auth-card h1 {
  font-size: 24px;
  color: #333;
  margin-bottom: 10px;
}

.subtitle {
  color: #666;
  font-size: 14px;
  margin-bottom: 20px;
}

.form-row {
  margin-bottom: 15px;
}

label {
  font-size: 13px;
  font-weight: bold;
  display: block;
  margin-bottom: 5px;
}

input[type="email"],
input[type="password"] {
  width: 100%;
  padding: 10px;
  border: 1px solid #aaa;
  border-radius: 5px;
}

input:focus {
  border-color: blue;
  outline: none;
}

.alert {
  padding: 10px;
  border-radius: 5px;
  margin-bottom: 15px;
  font-size: 13px;
}

.alert.error {
  background-color: #f8d7da;
  color: #721c24;
  border: 1px solid #f5c6cb;
}

.alert.success {
  background-color: #d4edda;
  color: #155724;
  border: 1px solid #c3e6cb;
}

.actions {
  margin-top: 20px;
}

.btn {
  width: 100%;
  padding: 10px;
  background-color: blue;
  color: white;
  border: none;
  border-radius: 5px;
  font-weight: bold;
  cursor: pointer;
}

.btn:hover {
  background-color: darkblue;
}

.auth-footer {
  text-align: center;
  margin-top: 20px;
  border-top: 1px solid #ccc;
  padding-top: 10px;
}

.auth-footer p {
  font-size: 13px;
  color: #666;
}

.auth-footer a {
  color: blue;
  text-decoration: none;
}

.auth-footer a:hover {
  text-decoration: underline;
}
</style>

</head>
<body>
  <div class="auth-page">
    <div class="auth-card">
      <h1>Welcome Back</h1>
      <p class="subtitle">Sign in to your account to continue</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert success"><%= success %></div>
      <% } %>

      <form method="POST" action="/login">
        <div class="form-row">
          <label for="email">Email Address</label>
          <input id="email" name="email" type="email" placeholder="you@example.com" value="<%= typeof email !== 'undefined' ? email : '' %>" required />
        </div>

        <div class="form-row">
          <label for="password">Password</label>
          <input id="password" name="password" type="password" placeholder="Your password" required />
        </div>

        <div class="actions">
          <button class="btn" type="submit">LoG In</button>
        </div>
      </form>

      <div class="auth-footer">
        <p>Don't have an account? <a href="/signup">Sign in now</a></p>
      </div>
    </div>
  </div>
</body>
</html>