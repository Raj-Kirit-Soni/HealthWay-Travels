<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Sign Up</title>
  <link rel="stylesheet" href="/styles/auth.css">
  <style>
   body {
  font-family: Arial, sans-serif;
  background-color: #dcd6f7;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.auth-page {
  width: 100%;
  max-width: 400px;
}

.auth-card {
  background-color: white;
  padding: 25px;
  border-radius: 10px;
  box-shadow: 0 0 10px gray;
}

.auth-card h1 {
  text-align: center;
  color: #333;
}

.subtitle {
  text-align: center;
  color: gray;
  margin-bottom: 20px;
  font-size: 14px;
}

.form-row {
  margin-bottom: 15px;
}

label {
  font-size: 14px;
  color: #333;
  display: block;
  margin-bottom: 5px;
}

input[type="text"],
input[type="email"],
input[type="password"] {
  width: 100%;
  padding: 10px;
  border: 1px solid #bbb;
  border-radius: 5px;
}

input:focus {
  border-color: #7b61ff;
  outline: none;
}

.btn {
  width: 100%;
  padding: 10px;
  background-color: #7b61ff;
  color: white;
  border: none;
  border-radius: 5px;
  cursor: pointer;
}

.btn:hover {
  background-color: #6a50e0;
}

.auth-footer {
  text-align: center;
  margin-top: 15px;
  font-size: 14px;
}

.auth-footer a {
  color: #7b61ff;
  text-decoration: none;
}

.auth-footer a:hover {
  text-decoration: underline;
}

  </style>
</head>
<body>
  <div class="auth-page">
    <div class="auth-card">
      <h1>Create Account</h1>
      <p class="subtitle">Join us and start exploring amazing destinations</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>

      <form method="POST" action="/signup">
        <div class="form-row">
          <label for="name">Full Name</label>
          <input id="name" name="name" type="text" placeholder="Raj Kirit Soni" value="<%= typeof name !== 'undefined' ? name : '' %>" />
        </div>

        <div class="form-row">
          <label for="email">Email Address</label>
          <input id="email" name="email" type="email" placeholder="you@example.com" value="<%= typeof email !== 'undefined' ? email : '' %>" required />
        </div>

        <div class="form-row">
          <label for="password">Password</label>
          <input id="password" name="password" type="password" placeholder="Choose a strong password" required />
        </div>

        <div class="actions">
          <button class="btn" type="submit">Create Account</button>
        </div>
      </form>

      <div class="auth-footer">
        <p>Already have an account? <a href="/login">Log in here</a></p>
      </div>
    </div>
  </div>
</body>
</html>